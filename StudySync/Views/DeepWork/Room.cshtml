@model StudySync.Models.FocusRoom
@{
    ViewData["Title"] = "DeepWork Room: " + Model.Title;
}

<style>
    /* DeepWork Room — 3-column studio layout */
    body > div.container { padding: 0 !important; max-width: 100% !important; margin-top: 0 !important; }
    footer { display: none !important; }

    .room-app {
        display: flex;
        height: calc(100vh - 64px);
        overflow: hidden;
        background: #0F1115;
    }

    /* ---- Main Stage (video) ---- */
    .stage {
        flex: 1;
        display: flex;
        flex-direction: column;
        position: relative;
        min-width: 0;
        background: #0a0a0f;
    }

    .stage-video {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
    }

    #mainScreen {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: none;
    }

    .stage-placeholder {
        text-align: center;
        color: rgba(255,255,255,0.45);
        padding: 2rem;
    }

    .stage-icon-wrap {
        width: 100px;
        height: 100px;
        border-radius: 28px;
        background: rgba(124, 58, 237, 0.15);
        border: 1px solid rgba(124, 58, 237, 0.25);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.5rem;
        font-size: 2.5rem;
        color: #A78BFA;
    }

    /* Stage action bar */
    .stage-bar {
        height: 58px;
        background: rgba(20, 18, 30, 0.95);
        backdrop-filter: blur(16px);
        border-top: 1px solid rgba(255,255,255,0.06);
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 20px;
        gap: 12px;
        flex-shrink: 0;
    }

    .stage-bar-label {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.82rem;
        color: rgba(255,255,255,0.45);
        font-weight: 600;
    }

    /* ---- Right Sidebar ---- */
    .room-sidebar {
        width: 320px;
        background: #16161e;
        border-left: 1px solid rgba(255,255,255,0.05);
        display: flex;
        flex-direction: column;
        flex-shrink: 0;
    }

    /* Tab bar */
    .sidebar-tabs {
        display: flex;
        border-bottom: 1px solid rgba(255,255,255,0.06);
        flex-shrink: 0;
    }

    .sidebar-tab {
        flex: 1;
        padding: 14px 8px;
        text-align: center;
        font-size: 0.82rem;
        font-weight: 700;
        color: rgba(255,255,255,0.35);
        cursor: pointer;
        transition: all 0.2s;
        border-bottom: 2px solid transparent;
        letter-spacing: 0.02em;
    }

    .sidebar-tab.active {
        color: #A78BFA;
        border-bottom-color: #7C3AED;
        background: rgba(124, 58, 237, 0.06);
    }

    .sidebar-tab:hover:not(.active) {
        color: rgba(255,255,255,0.65);
        background: rgba(255,255,255,0.03);
    }

    /* Tab panels */
    .tab-panel { display: none; flex-direction: column; flex: 1; min-height: 0; }
    .tab-panel.active { display: flex; }

    /* ---- Metrics Panel ---- */
    .metrics-panel {
        flex: 1;
        overflow-y: auto;
        padding: 16px;
    }

    .room-header-pill {
        text-align: center;
        padding: 16px 12px 12px;
        border-bottom: 1px solid rgba(255,255,255,0.05);
        flex-shrink: 0;
    }

    .timer-display {
        font-size: 3rem;
        font-weight: 800;
        color: #A78BFA;
        text-shadow: 0 0 20px rgba(167, 139, 250, 0.4);
        font-variant-numeric: tabular-nums;
        line-height: 1;
        letter-spacing: -0.02em;
    }

    .metric-tile {
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 14px;
        padding: 14px;
        text-align: center;
        transition: all 0.2s;
    }

    .metric-tile:hover { background: rgba(124,58,237,0.08); border-color: rgba(124,58,237,0.2); }

    /* ---- Chat Panel ---- */
    .chat-panel {
        flex: 1;
        overflow-y: auto;
        padding: 14px;
        display: flex;
        flex-direction: column;
        gap: 4px;
        scrollbar-width: thin;
        scrollbar-color: rgba(124,58,237,0.3) transparent;
    }

    .chat-panel::-webkit-scrollbar { width: 3px; }
    .chat-panel::-webkit-scrollbar-thumb { background: rgba(124,58,237,0.3); border-radius: 2px; }

    .chat-join-notice {
        text-align: center;
        padding: 1.5rem 1rem;
        color: rgba(255,255,255,0.3);
        font-size: 0.8rem;
    }

    .chat-join-notice i {
        display: block;
        font-size: 2rem;
        margin-bottom: 8px;
        color: #7C3AED;
        opacity: 0.5;
    }

    .room-msg {
        display: flex;
        gap: 10px;
        padding: 5px 4px;
        border-radius: 10px;
        transition: background 0.15s;
    }

    .room-msg:hover { background: rgba(255,255,255,0.03); }

    .room-msg-avatar {
        width: 32px;
        height: 32px;
        border-radius: 10px;
        background: linear-gradient(135deg, #7C3AED, #F472B6);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 800;
        font-size: 0.85rem;
        flex-shrink: 0;
    }

    .room-msg-body { flex: 1; min-width: 0; }

    .room-msg-meta {
        display: flex;
        align-items: baseline;
        gap: 7px;
        margin-bottom: 2px;
    }

    .room-msg-author {
        font-size: 0.82rem;
        font-weight: 700;
        color: #A78BFA;
    }

    .room-msg-time {
        font-size: 0.68rem;
        color: rgba(255,255,255,0.3);
    }

    .room-msg-text {
        font-size: 0.88rem;
        color: rgba(255,255,255,0.72);
        line-height: 1.45;
        word-break: break-word;
    }

    .system-msg {
        text-align: center;
        font-size: 0.72rem;
        color: rgba(255,255,255,0.25);
        padding: 4px 0;
    }

    /* Chat input */
    .chat-input-bar {
        padding: 12px;
        border-top: 1px solid rgba(255,255,255,0.06);
        flex-shrink: 0;
    }

    .chat-input-wrap {
        display: flex;
        align-items: center;
        background: rgba(255,255,255,0.06);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 12px;
        padding: 4px 6px 4px 12px;
        gap: 8px;
        transition: border-color 0.2s, box-shadow 0.2s;
    }

    .chat-input-wrap:focus-within {
        border-color: rgba(124, 58, 237, 0.5);
        box-shadow: 0 0 0 3px rgba(124, 58, 237, 0.12);
    }

    .chat-input-field {
        flex: 1;
        border: none;
        outline: none;
        background: transparent;
        font-size: 0.87rem;
        color: rgba(255,255,255,0.85);
        padding: 8px 0;
        font-family: 'Plus Jakarta Sans', sans-serif;
    }

    .chat-input-field::placeholder { color: rgba(255,255,255,0.25); }

    .chat-send-btn {
        width: 32px;
        height: 32px;
        background: linear-gradient(135deg, #7C3AED, #A78BFA);
        border: none;
        border-radius: 9px;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
        font-size: 0.85rem;
        flex-shrink: 0;
    }

    .chat-send-btn:hover { transform: scale(1.12); box-shadow: 0 4px 14px rgba(124,58,237,0.5); }
    .chat-send-btn:active { transform: scale(0.95); }
</style>

<div class="room-app">

    <!-- LEFT: video stage -->
    <div class="stage">
        <div class="stage-video">
            <video id="mainScreen" autoplay playsinline></video>

            <div id="noStreamPlaceholder" class="stage-placeholder">
                <div class="stage-icon-wrap">
                    <i class="bi bi-broadcast"></i>
                </div>
                <h4 class="fw-bold text-white mb-2">Awaiting Broadcast</h4>
                <p style="font-size:0.9rem;">Share your screen to go live, or wait for the host to start.</p>
            </div>
        </div>

        <!-- Stage action bar -->
        <div class="stage-bar">
            <div class="stage-bar-label">
                <i class="bi bi-shield-check text-success"></i>
                P2P Encrypted
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-sm fw-bold rounded-pill px-3 me-2" onclick="copyRoomInvite()" style="background:rgba(124,58,237,0.15);color:#A78BFA;font-size:0.82rem;border:1px solid rgba(124,58,237,0.3);">
                    <i class="bi bi-link-45deg me-1"></i>Copy Invite
                </button>
                <div id="roomInviteFeedback" class="text-success small" style="display:none;font-weight:600;font-size:0.75rem;position:absolute;top:-25px;right:180px;"><i class="bi bi-check-circle-fill me-1"></i>Link Copied!</div>

                <button id="btnShareScreen" class="btn btn-sm fw-bold rounded-pill px-3"
                        style="background:linear-gradient(135deg,#7C3AED,#A78BFA);color:#fff;font-size:0.82rem;box-shadow:0 4px 14px rgba(124,58,237,0.4);">
                    <i class="bi bi-display me-1"></i>Share Screen
                </button>
                <button id="btnStopShare" class="btn btn-sm btn-danger fw-bold rounded-pill px-3" style="display:none;font-size:0.82rem;">
                    <i class="bi bi-stop-circle me-1"></i>Stop
                </button>
                <form id="leaveRoomForm" asp-action="Leave" asp-route-id="@Model.Id" method="post" style="margin:0;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-outline-secondary fw-bold rounded-pill px-3" style="font-size:0.82rem;border-color:rgba(255,255,255,0.2);color:rgba(255,255,255,0.65);">
                        <i class="bi bi-box-arrow-right me-1"></i>Exit
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- RIGHT: sidebar (metrics + chat) -->
    <div class="room-sidebar">

        <!-- Tab bar -->
        <div class="sidebar-tabs">
            <div class="sidebar-tab active" data-tab="metrics" onclick="switchTab('metrics')">
                <i class="bi bi-activity me-1"></i>Session
            </div>
            <div class="sidebar-tab" data-tab="chat" onclick="switchTab('chat')">
                <i class="bi bi-chat-dots me-1"></i>Room Chat
                <span id="chatBadge" style="display:none;background:#F472B6;color:white;border-radius:50%;width:14px;height:14px;font-size:0.6rem;display:inline-flex;align-items:center;justify-content:center;margin-left:4px;" id="chatUnread">●</span>
            </div>
        </div>

        <!-- METRICS TAB -->
        <div class="tab-panel active" id="tab-metrics">
            <!-- Room header -->
            <div class="room-header-pill">
                <span class="badge rounded-pill px-3 py-1 mb-2 d-inline-flex align-items-center gap-1"
                      style="background:rgba(244,114,182,0.15);color:#F472B6;border:1px solid rgba(244,114,182,0.25);font-size:0.72rem;">
                    <span style="width:6px;height:6px;background:#F472B6;border-radius:50%;animation:pulseDot 1.2s infinite;"></span>
                    @(Model.DurationMinutes == 0 ? "Open Session" : "Live Session")
                </span>
                <div class="timer-display mb-1" id="countdown-timer">--:--</div>
                <div style="color:rgba(255,255,255,0.4);font-size:0.8rem;font-weight:700;">@Model.Title</div>
                <div style="color:rgba(255,255,255,0.3);font-size:0.75rem;margin-top:2px;">
                    <i class="bi bi-tag-fill me-1 text-primary opacity-50"></i>@Model.Topic
                </div>
            </div>

            <!-- Metrics -->
            <div class="metrics-panel">
                <div class="row g-3 mb-3">
                    <div class="col-6">
                        <div class="metric-tile">
                            <i class="bi bi-people-fill d-block mb-1 text-info" style="font-size:1.8rem;"></i>
                            <div class="fw-bold text-white" style="font-size:1.4rem;">@Model.FocusSessions.Count</div>
                            <div style="font-size:0.68rem;color:rgba(255,255,255,0.35);">Peers Connected</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="metric-tile">
                            <i class="bi bi-hdd-network d-block mb-1 text-warning" style="font-size:1.8rem;"></i>
                            <div class="fw-bold text-white" id="pingMetric" style="font-size:1.4rem;">--</div>
                            <div style="font-size:0.68rem;color:rgba(255,255,255,0.35);">P2P Ping</div>
                        </div>
                    </div>
                </div>

                <!-- Focus Points hint -->
                <div class="rounded-3 p-3 mt-2" style="background:rgba(124,58,237,0.1);border:1px solid rgba(124,58,237,0.15);">
                    <div style="font-size:0.78rem;color:rgba(255,255,255,0.5);line-height:1.6;">
                        <i class="bi bi-lightning-fill text-warning me-1"></i>
                        <strong style="color:rgba(255,255,255,0.7);">Focus Points</strong> are rewarded based on duration. Stay in the session to earn more!
                    </div>
                </div>
            </div>
        </div>

        <!-- CHAT TAB -->
        <div class="tab-panel" id="tab-chat">
            <div class="chat-panel" id="roomChatHistory">
                <div class="chat-join-notice">
                    <i class="bi bi-chat-dots"></i>
                    Session chat is ephemeral — messages only last while you're in this room.
                </div>
            </div>

            <div class="chat-input-bar">
                <div class="chat-input-wrap">
                    <input type="text" id="roomChatInput" class="chat-input-field"
                           placeholder="Message the room..." autocomplete="off" maxlength="500" />
                    <button class="chat-send-btn" id="roomChatSend" title="Send">
                        <i class="bi bi-send-fill" style="font-size:0.8rem;"></i>
                    </button>
                </div>
                <div style="text-align:center;margin-top:5px;font-size:0.67rem;color:rgba(255,255,255,0.2);">
                    Press <kbd style="padding:1px 5px;border-radius:4px;background:rgba(124,58,237,0.15);color:#A78BFA;border:1px solid rgba(124,58,237,0.2);">Enter</kbd> to send
                </div>
            </div>
        </div>
    </div>
</div>

<input type="hidden" id="roomIdField" value="@Model.Id" />

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<script src="~/js/webrtc.js"></script>
<script>
    // ---- Tab Switcher ----
    function switchTab(tabName) {
        document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
        document.querySelectorAll('.sidebar-tab').forEach(t => t.classList.remove('active'));
        document.getElementById('tab-' + tabName)?.classList.add('active');
        document.querySelector(`[data-tab="${tabName}"]`)?.classList.add('active');
        if (tabName === 'chat') {
            document.getElementById('chatBadge').style.display = 'none';
            // scroll chat to bottom
            const h = document.getElementById('roomChatHistory');
            if (h) h.scrollTop = h.scrollHeight;
        }
    }

    // ---- Timer ----
    document.addEventListener('DOMContentLoaded', function () {
        const timerDisplay = document.getElementById('countdown-timer');
        const leaveForm = document.getElementById('leaveRoomForm');
        const isOpenSession = @(Model.DurationMinutes == 0 ? "true" : "false");

        if (isOpenSession) {
            const joinTime = new Date().getTime();
            function updateStopwatch() {
                const dist = new Date().getTime() - joinTime;
                const h   = Math.floor(dist / 3600000);
                const m   = Math.floor((dist % 3600000) / 60000);
                const s   = Math.floor((dist % 60000) / 1000);
                const hPart = h > 0 ? String(h).padStart(2,'0') + ':' : '';
                timerDisplay.textContent = `${hPart}${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
            }
            updateStopwatch();
            setInterval(updateStopwatch, 1000);
        } else {
            const endTime = new Date('@Model.EndTime.ToString("s")' + 'Z').getTime();
            function updateCountdown() {
                const dist = endTime - new Date().getTime();
                if (dist <= 0) {
                    timerDisplay.textContent = '00:00';
                    timerDisplay.style.color = '#FB7185';
                    setTimeout(() => leaveForm.submit(), 1000);
                    return;
                }
                const m = Math.floor((dist % 3600000) / 60000);
                const s = Math.floor((dist % 60000) / 1000);
                timerDisplay.textContent = `${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
            }
            updateCountdown();
            setInterval(updateCountdown, 1000);
        }

        // ---- SignalR Room Chat ----
        const roomId = document.getElementById('roomIdField')?.value;
        const chatHistory = document.getElementById('roomChatHistory');
        const chatInput   = document.getElementById('roomChatInput');
        const chatSendBtn = document.getElementById('roomChatSend');
        const chatBadge   = document.getElementById('chatBadge');

        if (!roomId || !chatHistory) return;

        const connection = new signalR.HubConnectionBuilder()
            .withUrl('/chatHub')
            .withAutomaticReconnect()
            .build();

        function appendSystemMsg(text) {
            const div = document.createElement('div');
            div.className = 'system-msg';
            div.textContent = text;
            chatHistory.appendChild(div);
            chatHistory.scrollTop = chatHistory.scrollHeight;
        }

        function appendMsg(fullname, initial, message, time) {
            const row = document.createElement('div');
            row.className = 'room-msg';
            row.innerHTML = `
                <div class="room-msg-avatar">${initial}</div>
                <div class="room-msg-body">
                    <div class="room-msg-meta">
                        <span class="room-msg-author">${fullname}</span>
                        <span class="room-msg-time">${time}</span>
                    </div>
                    <div class="room-msg-text">${message}</div>
                </div>
            `;
            chatHistory.appendChild(row);
            chatHistory.scrollTop = chatHistory.scrollHeight;

            // Show badge if chat tab not active
            const chatTabActive = document.getElementById('tab-chat')?.classList.contains('active');
            if (!chatTabActive) {
                chatBadge.style.display = 'inline-flex';
            }
        }

        connection.on('ReceiveRoomMessage', appendMsg);

        connection.on('RoomUserJoined', (name) => {
            appendSystemMsg(`${name} joined the session 👋`);
        });

        connection.start()
            .then(() => connection.invoke('JoinRoom', roomId).catch(console.error))
            .catch(console.error);

        function sendMsg() {
            const msg = chatInput?.value?.trim();
            if (msg) {
                connection.invoke('SendRoomMessage', roomId, msg).catch(console.error);
                chatInput.value = '';
            }
        }

        chatInput?.addEventListener('keypress', e => { if (e.key === 'Enter') sendMsg(); });
        chatSendBtn?.addEventListener('click', sendMsg);
    });

    // Copy Room Invite Link
    window.copyRoomInvite = function() {
        const dummy = document.createElement('input');
        document.body.appendChild(dummy);
        dummy.value = window.location.href; // The current secure room url
        dummy.select();
        document.execCommand('copy');
        document.body.removeChild(dummy);
        
        const feedback = document.getElementById("roomInviteFeedback");
        if (feedback) {
            feedback.style.display = "block";
            setTimeout(() => feedback.style.display = "none", 3000);
        }
    };
</script>
}
