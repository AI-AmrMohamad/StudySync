@model List<StudySync.Models.FocusRoom>
@{
    ViewData["Title"] = "DeepWork Hub";
}

<div class="row align-items-center mb-5">
    <div class="col-lg-8">
        <h1 class="display-4 fw-bold">
            <i class="bi bi-clock-history text-warning me-2"></i> DeepWork Hub
        </h1>
        <p class="text-muted fs-5">Join synchronous study sessions, stay focused, and earn Focus Points.</p>
    </div>
</div>

<div class="row g-4 mb-5">
    <!-- Active Rooms List -->
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 pt-4 px-4 pb-2">
                <h4 class="fw-bold mb-0">Active Focus Rooms</h4>
            </div>
            <div class="card-body p-4 pt-2">
                @if (Model.Any())
                {
                    <div class="row g-3">
                        @foreach (var room in Model)
                        {
                            <div class="col-md-6">
                                <div class="card border border-primary border-opacity-25 h-100 hover-lift" style="background: rgba(108, 92, 231, 0.03);">
                                    <div class="card-body">
                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                            <h5 class="fw-bold mb-0">@room.Title</h5>
                                            <span class="badge bg-success rounded-pill px-2 py-1"><i class="bi bi-broadcast me-1"></i>Live</span>
                                        </div>
                                        <p class="text-muted mb-3"><i class="bi bi-tag-fill me-1"></i>@room.Topic</p>
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div class="small">
                                                <i class="bi bi-people-fill text-muted me-1"></i> @room.FocusSessions.Count Students
                                            </div>
                                            <a asp-action="Room" asp-route-id="@room.Id" class="btn btn-sm btn-primary">
                                                Join Room <i class="bi bi-arrow-right ms-1"></i>
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-state p-5 bg-white rounded-4 shadow-sm border border-light mt-3 text-center">
                        <i class="bi bi-moon-stars text-primary opacity-50 mb-3 d-block" style="font-size: 5rem;"></i>
                        <h4 class="fw-bold mt-3">It's quiet in here...</h4>
                        <p class="text-muted mb-4 lead">No active rooms right now. Be the first to start a focus session!</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Create Room Form -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm h-100 wallet-card-points" style="border-radius: var(--ss-radius-lg);">
            <div class="card-body p-4 text-white">
                <h4 class="fw-bold mb-4"><i class="bi bi-plus-circle me-2"></i>Start a Session</h4>
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-white-50">Room Title</label>
                        <input type="text" name="title" class="form-control" placeholder="e.g. Late Night Math" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-white-50">Study Topic</label>
                        <input type="text" name="topic" class="form-control" placeholder="Calculus III" required />
                    </div>
                    <div class="mb-4">
                        <label class="form-label small fw-bold text-white-50">Duration (Minutes)</label>
                        <select name="durationMinutes" class="form-select">
                            <option value="0">Open Session (No Time Limit)</option>
                            <option value="1">1 Min (Test)</option>
                            <option value="15">15 Mins</option>
                            <option value="25" selected>25 Mins (Pomodoro)</option>
                            <option value="50">50 Mins</option>
                            <option value="90">90 Mins</option>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-light w-100 fw-bold text-danger hover-lift">
                        <i class="bi bi-play-fill me-1"></i> Launch Focus Room
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
