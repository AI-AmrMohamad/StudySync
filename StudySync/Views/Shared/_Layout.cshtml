<!DOCTYPE html>
<html lang="en">
@using Microsoft.AspNetCore.Identity
@using StudySync.Models
@inject UserManager<ApplicationUser> UserManager
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - StudySync</title>
    <meta name="description" content="StudySync — The campus hub for chatting, live streaming, skill swapping, and deep focus." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/StudySync.styles.css" asp-append-version="true" />
</head>
<body>

    <header>
        <nav class="navbar navbar-expand-lg navbar-dark navbar-glass sticky-top">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center gap-2" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="d-flex align-items-center justify-content-center rounded-3 shadow-sm"
                          style="width:32px;height:32px;background:linear-gradient(135deg,#7C3AED,#F472B6);">
                        <i class="bi bi-lightning-charge-fill text-white" style="font-size:1rem;"></i>
                    </span>
                    StudySync
                </a>

                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse"
                        data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false"
                        aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto ms-3 gap-1">
                        <li class="nav-item">
                            <a class="nav-link nav-link-underline" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door me-1"></i>Home
                            </a>
                        </li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link nav-link-underline" asp-controller="Dashboard" asp-action="Index">
                                    <i class="bi bi-grid-1x2 me-1 text-warning"></i>Dashboard
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-link-underline" asp-controller="Session" asp-action="Browse">
                                    <i class="bi bi-calendar-event me-1" style="color:#F472B6;"></i>Sessions
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-link-underline" asp-controller="Community" asp-action="Index">
                                    <i class="bi bi-chat-dots me-1 text-info"></i>Community
                                </a>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav align-items-center gap-2">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            var currentUser = await UserManager.GetUserAsync(User);
                            var displayName = currentUser?.FullName ?? User.Identity.Name?.Split('@').FirstOrDefault() ?? "Student";
                            var initial = string.IsNullOrWhiteSpace(displayName) ? "S" : displayName.Substring(0, 1).ToUpper();
                            var photoPath = currentUser?.ProfilePhotoPath;
                            var isAdmin = User.IsInRole("Admin");

                            if (isAdmin)
                            {
                                <li class="nav-item">
                                    <a asp-controller="Admin" asp-action="Index"
                                       class="nav-link nav-link-underline fw-bold"
                                       style="color:#F472B6;">
                                        <i class="bi bi-shield-lock-fill me-1"></i>Admin
                                    </a>
                                </li>
                            }

                            <li class="nav-item">
                                <a asp-controller="Profile" asp-action="Index" class="badge text-white px-3 py-2 d-flex align-items-center gap-2 hover-lift text-decoration-none"
                                      style="background:rgba(167,139,250,0.2);border:1px solid rgba(167,139,250,0.25);border-radius:2rem;font-size:0.8rem;transition:all 0.2s;">
                                    @if (!string.IsNullOrEmpty(photoPath))
                                    {
                                        <img src="@photoPath" alt="@displayName"
                                             style="width:22px;height:22px;border-radius:50%;object-fit:cover;" />
                                    }
                                    else
                                    {
                                        <span class="d-flex align-items-center justify-content-center rounded-circle"
                                              style="width:22px;height:22px;background:linear-gradient(135deg,#7C3AED,#F472B6);font-size:0.7rem;font-weight:800;">
                                            @initial
                                        </span>
                                    }
                                    @displayName
                                </a>
                            </li>
                            <li class="nav-item">
                                <form asp-area="Identity" asp-page="/Account/Logout" method="post"
                                      asp-route-returnUrl="@Url.Action("Index", "Home")">
                                    <button type="submit" class="btn btn-sm btn-glass" style="font-size:0.8rem;">
                                        <i class="bi bi-box-arrow-right me-1"></i>Logout
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-sm btn-glass" style="font-size:0.82rem;"
                                   asp-area="Identity" asp-page="/Account/Register">
                                    <i class="bi bi-person-plus me-1"></i>Register
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-sm btn-primary" style="font-size:0.82rem;"
                                   asp-area="Identity" asp-page="/Account/Login">
                                    <i class="bi bi-box-arrow-in-right me-1"></i>Log In
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container mt-4">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show fade-in-up" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show fade-in-up" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-glass mt-5 py-5 text-center">
        <div class="container">
            <div class="mb-3">
                <span class="d-inline-flex align-items-center justify-content-center rounded-3 shadow-sm mb-2"
                      style="width:44px;height:44px;background:linear-gradient(135deg,#7C3AED,#F472B6);">
                    <i class="bi bi-lightning-charge-fill text-white fs-5"></i>
                </span>
            </div>
            <span style="font-weight:800; font-size:1.1rem; letter-spacing:-0.03em;"
                  class="text-gradient-candy">StudySync</span>
            <p class="mt-2 mb-0" style="color:rgba(255,255,255,0.45); font-size:0.85rem;">
                Built for students, by students. <i class="bi bi-stars text-warning ms-1"></i>
            </p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
