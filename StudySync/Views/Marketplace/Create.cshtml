@model StudySync.Models.ViewModels.CreateBookingViewModel
@{
    ViewData["Title"] = "New Swap Request";
}

<div class="row justify-content-center mt-3">
    <div class="col-md-8 col-lg-6">
        <div class="card border-0 shadow-sm" style="border-radius: 1.5rem; overflow: hidden; max-width: 550px; margin: 0 auto;">
            <div class="card-header border-0 py-4 px-4" style="background: #8983F3; border-radius: 1.5rem 1.5rem 0 0;">
                <h3 class="mb-1 fw-bold" style="color: #2D3436;">
                    <i class="bi bi-rocket-takeoff-fill" style="color: #2D3436;"></i> Start a Skill Swap
                </h3>
                <p class="mb-0 mt-1" style="color: rgba(255,255,255,0.9); font-size: 0.95rem;">Connect with a tutor and grow your skills</p>
            </div>
            <div class="card-body p-5">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="All" class="text-danger mb-4 rounded-3 text-start small"></div>

                    <div class="mb-4">
                        <label asp-for="SkillId" class="form-label fw-bold mb-3 d-inline-block" style="background: #A29BFE; color: white; padding: 0.2rem 0.5rem; border-radius: 0.2rem;">
                            Subject Category
                        </label>
                        <div class="input-group input-group-lg shadow-sm rounded-3">
                            <span class="input-group-text bg-white border-end-0 text-muted"><i class="bi bi-book"></i></span>
                            <select asp-for="SkillId" class="form-select border-start-0 ps-0 text-dark" id="skill-select" style="font-size: 1rem;">
                                <option value="">-- Choose what you want to learn --</option>
                                @foreach (var skill in Model.AvailableSkills)
                                {
                                    <option value="@skill.Id">@skill.Name (@skill.Category)</option>
                                }
                            </select>
                        </div>
                        <span asp-validation-for="SkillId" class="text-danger small mt-1"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ProviderEmail" class="form-label fw-bold mb-2 text-dark">
                            Tutor's Email
                        </label>
                        <div class="input-group input-group-lg shadow-sm rounded-3">
                            <span class="input-group-text bg-white border-end-0 text-muted"><i class="bi bi-person-badge"></i></span>
                            <input asp-for="ProviderEmail" class="form-control border-start-0 ps-0 text-dark"
                                   placeholder="e.g. alice@studysync.com" id="provider-email-input" style="font-size: 1rem;" />
                        </div>
                        <span asp-validation-for="ProviderEmail" class="text-danger small mt-1"></span>
                        <div class="form-text mt-2"><i class="bi bi-info-circle me-1"></i>The email of the student who will teach you.</div>
                    </div>

                    <div class="mb-5">
                        <label asp-for="CreditCost" class="form-label fw-bold d-flex justify-content-between align-items-end mb-2 text-dark">
                            <span>Credit Reward</span>
                            <span class="badge bg-warning text-dark px-3 py-1 shadow-sm rounded-pill"><i class="bi bi-coin me-1"></i>Time-Credits</span>
                        </label>
                        <div class="input-group input-group-lg shadow-sm rounded-3">
                            <span class="input-group-text bg-white border-end-0"><i class="bi bi-cash-coin text-warning"></i></span>
                            <input asp-for="CreditCost" class="form-control border-start-0 ps-0 text-dark" type="number"
                                   min="1" max="10" id="credit-cost-input" style="font-size: 1rem;" />
                        </div>
                        <span asp-validation-for="CreditCost" class="text-danger small mt-1"></span>
                        <div class="form-text mt-2">How many credits you're offering for this session (1-10).</div>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-lg fw-bold shadow-sm hover-lift text-white" style="background: #8983F3; border-radius: 50rem;" id="submit-booking-btn">
                            <i class="bi bi-send me-2"></i>Send Request
                        </button>
                        <a asp-action="Index" class="btn btn-light fw-bold hover-lift text-muted">
                            Cancel
                        </a>
                    </div>
                </form>
            </div>
            <div class="card-footer bg-white border-0 py-3 text-center text-muted" style="font-size: 0.85rem;">
                <i class="bi bi-shield-check me-1 text-success"></i> Credits are protected by Double-Handshake Escrow
            </div>
        </div>
    </div>
</div>
