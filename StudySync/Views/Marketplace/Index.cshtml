@model List<StudySync.Models.ViewModels.SwapBookingViewModel>
@{
    ViewData["Title"] = "Skill-Swap Marketplace";
}

<div class="row mb-5 align-items-center">
    <div class="col-md-8">
        <h1 class="display-5 fw-bold mb-1 section-title">
            <i class="bi bi-shop me-2" style="font-size: 2.5rem;"></i> Skill-Swap Marketplace
        </h1>
        <p class="text-muted fs-5 mb-0">Manage your active swaps and build your knowledge network</p>
    </div>
    <div class="col-md-4 text-md-end mt-3 mt-md-0">
        <a asp-action="Create" class="btn btn-primary btn-lg shadow-sm hover-lift" id="create-booking-btn">
            <i class="bi bi-plus-circle me-2"></i>New Swap Request
        </a>
    </div>
</div>

@if (Model.Any())
{
    <div class="row g-4">
        @foreach (var booking in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 border-0 shadow-sm align-items-stretch d-flex flex-column hover-lift">
                    <div class="card-header bg-white border-bottom-0 pt-4 px-4 pb-0 d-flex justify-content-between align-items-start">
                        <h4 class="mb-0 fw-bold">@booking.SkillName</h4>
                        @{
                            var statusClass = booking.Status switch
                            {
                                StudySync.Models.BookingStatus.Pending => "bg-warning text-dark",
                                StudySync.Models.BookingStatus.Confirmed => "bg-success",
                                StudySync.Models.BookingStatus.Completed => "bg-primary",
                                _ => "bg-secondary"
                            };
                        }
                        <span class="badge @statusClass rounded-pill px-3 py-2 shadow-sm">@booking.Status</span>
                    </div>
                    
                    <div class="card-body p-4 flex-grow-1">
                        <div class="d-flex align-items-center gap-3 mb-3 p-3 rounded-3" style="background: rgba(0,0,0,0.02);">
                            <div class="bg-white rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width: 40px; height: 40px;">
                                <i class="bi bi-person text-muted fs-5"></i>
                            </div>
                            <div>
                                <small class="text-muted d-block text-uppercase" style="font-size: 0.65rem; letter-spacing: 0.05em;">Exchange With</small>
                                <strong class="fs-5">@booking.OtherUserName</strong>
                            </div>
                        </div>

                        <div class="row g-2 mb-4">
                            <div class="col-6">
                                <div class="p-2 border rounded-3 text-center">
                                    <small class="text-muted d-block mb-1" style="font-size: 0.7rem;">Your Role</small>
                                    <span class="badge @(booking.Role == "Requester" ? "bg-info text-dark" : "bg-primary") w-100 py-2">
                                        <i class="bi @(booking.Role == "Requester" ? "bi-arrow-up-right" : "bi-arrow-down-left") me-1"></i>
                                        @booking.Role
                                    </span>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="p-2 border rounded-3 text-center">
                                    <small class="text-muted d-block mb-1" style="font-size: 0.7rem;">Credit Cost</small>
                                    <div class="fw-bold fs-6">
                                        <i class="bi bi-coin text-warning me-1"></i>@booking.CreditCost
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between px-2 pt-3 border-top">
                            <div class="text-center">
                                <i class="bi @(booking.RequesterConfirmed ? "bi-check-circle-fill text-success" : "bi-circle text-muted") fs-5 d-block mb-1"></i>
                                <small class="@(booking.RequesterConfirmed ? "text-success fw-bold" : "text-muted")" style="font-size: 0.75rem;">Requester</small>
                            </div>
                            <div class="text-muted fs-4">
                                <i class="bi bi-arrow-left-right"></i>
                            </div>
                            <div class="text-center">
                                <i class="bi @(booking.ProviderConfirmed ? "bi-check-circle-fill text-success" : "bi-circle text-muted") fs-5 d-block mb-1"></i>
                                <small class="@(booking.ProviderConfirmed ? "text-success fw-bold" : "text-muted")" style="font-size: 0.75rem;">Provider</small>
                            </div>
                        </div>
                    </div>
                    
                    @if (booking.Status == StudySync.Models.BookingStatus.Pending)
                    {
                        var alreadyConfirmed = (booking.Role == "Requester" && booking.RequesterConfirmed)
                                            || (booking.Role == "Provider" && booking.ProviderConfirmed);
                        <div class="card-footer bg-white border-top-0 p-4 pt-0">
                            @if (!alreadyConfirmed)
                            {
                                <form asp-action="Confirm" asp-route-id="@booking.Id" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-primary w-100 py-2 fw-bold" id="confirm-btn-@booking.Id">
                                        <i class="bi bi-check2-circle me-2"></i>Confirm Handshake
                                    </button>
                                </form>
                            }
                            else
                            {
                                <div class="bg-light rounded-3 p-2 text-center text-success fw-bold border border-success border-opacity-25">
                                    <i class="bi bi-hourglass-split me-2"></i>Waiting on partner
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="empty-state p-5 bg-white rounded-4 shadow-sm border border-light mt-4">
        <div class="empty-state-icon">
            <i class="bi bi-emoji-sunglasses text-primary" style="font-size: 6rem; opacity: 0.6;"></i>
        </div>
        <h4 class="fw-bold mt-3">It's quiet in here...</h4>
        <p class="text-muted mb-4 lead">You haven't requested or provided any skill swaps yet. Dive in and start exchanging knowledge!</p>
        <a asp-action="Create" class="btn btn-primary btn-lg shadow hover-lift rounded-pill px-5">
            <i class="bi bi-rocket-takeoff me-2"></i>Post a Request Now
        </a>
    </div>
}
