@model StudySync.Models.ViewModels.CreateSessionViewModel
@{
    ViewData["Title"] = "Host a Session";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="fw-bold gradient-text m-0">Host a New Session</h2>
                <a asp-action="Browse" class="btn btn-outline-secondary rounded-pill">Cancel</a>
            </div>

            <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>

                    <h5 class="fw-bold mb-3"><i class="bi bi-info-circle text-primary me-2"></i>Session Details</h5>
                    <div class="form-floating mb-3">
                        <input asp-for="Title" class="form-control" placeholder="e.g. Master React Hooks in 1 Hour" />
                        <label asp-for="Title"></label>
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input asp-for="Topic" class="form-control" placeholder="e.g. React" />
                                <label asp-for="Topic"></label>
                                <span asp-validation-for="Topic" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input asp-for="Category" class="form-control" placeholder="e.g. Programming" />
                                <label asp-for="Category"></label>
                                <span asp-validation-for="Category" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-floating mb-4">
                        <textarea asp-for="Description" class="form-control" style="height: 120px" placeholder="Describe what attendees will learn..."></textarea>
                        <label asp-for="Description"></label>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <hr class="my-4" />
                    <h5 class="fw-bold mb-3"><i class="bi bi-calendar-check text-primary me-2"></i>Schedule & Logistics</h5>
                    
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input asp-for="ScheduledAt" class="form-control" type="datetime-local" />
                                <label asp-for="ScheduledAt"></label>
                                <span asp-validation-for="ScheduledAt" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input asp-for="DurationMinutes" class="form-control" type="number" min="15" max="480" />
                                <label asp-for="DurationMinutes"></label>
                                <span asp-validation-for="DurationMinutes" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row g-3 mb-5">
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input asp-for="CreditCost" class="form-control" type="number" min="1" max="50" />
                                <label asp-for="CreditCost"></label>
                                <span asp-validation-for="CreditCost" class="text-danger small"></span>
                            </div>
                            <small class="text-muted d-block mt-1">Attendees will pay this amount to join.</small>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input asp-for="MaxAttendees" class="form-control" type="number" min="1" max="100" />
                                <label asp-for="MaxAttendees"></label>
                                <span asp-validation-for="MaxAttendees" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary btn-lg rounded-pill fw-bold hover-lift">
                            <i class="bi bi-calendar-plus me-2"></i>Create Session
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
