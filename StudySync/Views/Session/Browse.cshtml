@model StudySync.Models.ViewModels.SessionBrowseViewModel
@{
    ViewData["Title"] = "Session Marketplace";
}

<div class="container py-5">
    <div class="row mb-5 align-items-center">
        <div class="col-md-8">
            <h1 class="display-4 fw-bold gradient-text mb-3">Session Marketplace</h1>
            <p class="lead text-muted">Discover and join live teaching sessions. Use your credits to learn from peers.</p>
        </div>
        <div class="col-md-4 text-md-end mt-3 mt-md-0">
            <a asp-action="Create" class="btn btn-primary btn-lg rounded-pill fw-bold shadow-sm hover-lift">
                <i class="bi bi-plus-lg me-2"></i>Host a Session
            </a>
        </div>
    </div>

    <!-- Filters & Search -->
    <div class="card border-0 shadow-sm rounded-4 p-4 mb-5" style="background: rgba(255,255,255,0.8); backdrop-filter: blur(10px);">
        <form method="get" asp-action="Browse" class="row g-3">
            <div class="col-md-4">
                <div class="input-group input-group-lg">
                    <span class="input-group-text bg-white border-end-0 text-muted"><i class="bi bi-search"></i></span>
                    <input type="text" name="q" value="@Model.SearchQuery" class="form-control border-start-0 ps-0" placeholder="Search sessions or hosts...">
                </div>
            </div>
            <div class="col-md-4">
                <select name="category" class="form-select form-select-lg">
                    <option value="">All Categories</option>
                    @foreach (var cat in Model.Categories)
                    {
                        if (Model.SelectedCategory == cat)
                        {
                            <option value="@cat" selected>@cat</option>
                        }
                        else
                        {
                            <option value="@cat">@cat</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-4">
                <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill fw-bold">Filter</button>
            </div>
        </form>
    </div>

    @if (!Model.Sessions.Any())
    {
        <div class="text-center py-5">
            <div class="display-1 text-muted mb-4"><i class="bi bi-calendar-x"></i></div>
            <h3 class="fw-bold">No sessions found</h3>
            <p class="text-muted">Try adjusting your filters or be the first to host a session!</p>
            <a asp-action="Browse" class="btn btn-outline-primary rounded-pill mt-3">Clear Filters</a>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var session in Model.Sessions)
            {
                <div class="col">
                    <div class="card h-100 border-0 shadow-sm rounded-4 hover-lift overflow-hidden position-relative">
                        @if (session.IsEnrolled)
                        {
                            <div class="position-absolute top-0 end-0 p-3 z-index-1">
                                <span class="badge bg-success rounded-pill shadow-sm"><i class="bi bi-check-circle me-1"></i>Enrolled</span>
                            </div>
                        }
                        @if (session.IsHost)
                        {
                            <div class="position-absolute top-0 end-0 p-3 z-index-1">
                                <span class="badge bg-primary rounded-pill shadow-sm"><i class="bi bi-person-video3 me-1"></i>Hosting</span>
                            </div>
                        }

                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <span class="badge bg-soft-primary text-primary rounded-pill px-3 py-2">@session.Category</span>
                                <div class="text-end">
                                    <span class="fs-5 fw-bold text-success"><i class="bi bi-coin me-1"></i>@session.CreditCost</span>
                                </div>
                            </div>
                            
                            <h4 class="fw-bold mb-2 text-truncate" title="@session.Title">@session.Title</h4>
                            <p class="text-muted small mb-3"><i class="bi bi-tag-fill me-1"></i>@session.Topic</p>
                            
                            <div class="d-flex align-items-center mb-4">
                                <div class="avatar me-3" style="width: 40px; height: 40px; border-radius: 50%; overflow: hidden; background: var(--ss-primary); color: white; display: flex; align-items: center; justify-content: center; font-weight: bold;">
                                    @if (!string.IsNullOrEmpty(session.HostPhotoPath))
                                    {
                                        <img src="@session.HostPhotoPath" alt="@session.HostName" style="width:100%; height:100%; object-fit:cover;" />
                                    }
                                    else
                                    {
                                        @session.HostName.Substring(0,1).ToUpper()
                                    }
                                </div>
                                <div>
                                    <h6 class="mb-0 fw-bold">@session.HostName</h6>
                                    <small class="text-warning"><i class="bi bi-star-fill me-1"></i>@session.HostRating.ToString("0.0")</small>
                                </div>
                            </div>

                            <div class="bg-light rounded-3 p-3 mb-4">
                                <div class="d-flex align-items-center mb-2">
                                    <i class="bi bi-calendar-event text-primary me-2"></i>
                                    <span class="fw-medium">@session.ScheduledAt.ToString("MMM dd, yyyy • h:mm tt")</span>
                                </div>
                                <div class="d-flex align-items-center text-muted small">
                                    <i class="bi bi-clock me-2"></i>
                                    <span>@session.DurationMinutes mins</span>
                                    <span class="mx-2">•</span>
                                    <i class="bi bi-people me-2"></i>
                                    <span>@session.EnrolledCount / @session.MaxAttendees spots</span>
                                </div>
                            </div>

                            <a asp-action="Details" asp-route-id="@session.Id" class="btn btn-outline-primary w-100 rounded-pill fw-bold stretched-link">View Details</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
