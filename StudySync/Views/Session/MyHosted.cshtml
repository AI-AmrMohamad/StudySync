@model List<StudySync.Models.ViewModels.UpcomingSessionViewModel>
@{
    ViewData["Title"] = "My Hosted Sessions";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <h1 class="display-5 fw-bold gradient-text m-0">My Hosted Sessions</h1>
        <a asp-action="Create" class="btn btn-primary rounded-pill fw-bold hover-lift shadow-sm">
            <i class="bi bi-plus-lg me-2"></i>Host New
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="card border-0 shadow-sm rounded-4 p-5 text-center bg-white">
            <div class="display-1 text-muted mb-4"><i class="bi bi-camera-video-off"></i></div>
            <h3 class="fw-bold">You aren't hosting any sessions</h3>
            <p class="text-muted mb-4">Share your knowledge and earn credits by hosting a session.</p>
            <a asp-action="Create" class="btn btn-primary btn-lg rounded-pill px-4 fw-bold shadow-sm">Host a Session Now</a>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-lg-2 g-4">
            @foreach (var session in Model)
            {
                <div class="col">
                    <div class="card h-100 border-0 shadow-sm rounded-4 position-relative 
                         @(session.Status == StudySync.Models.SessionStatus.Cancelled ? "opacity-75" : "")">
                        
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div>
                                    <span class="badge bg-primary rounded-pill me-2">@session.Category</span>
                                    @if (session.Status == StudySync.Models.SessionStatus.Completed)
                                    {
                                        <span class="badge bg-success rounded-pill">Completed</span>
                                    }
                                    else if (session.Status == StudySync.Models.SessionStatus.Cancelled)
                                    {
                                        <span class="badge bg-danger rounded-pill">Cancelled</span>
                                    }
                                </div>
                                <span class="fw-bold text-success fs-5"><i class="bi bi-coin me-1"></i>@session.CreditCost</span>
                            </div>

                            <h4 class="fw-bold mb-1">@session.Title</h4>
                            <p class="text-muted small mb-3">@session.Topic</p>

                            <div class="d-flex flex-column gap-2 mb-4">
                                <div class="d-flex align-items-center">
                                    <div class="bg-light rounded p-2 me-3 text-primary"><i class="bi bi-calendar-event"></i></div>
                                    <div>
                                        <span class="d-block fw-bold">@session.ScheduledAt.ToString("MMM dd, yyyy")</span>
                                        <small class="text-muted">@session.ScheduledAt.ToString("h:mm tt") • @session.DurationMinutes mins</small>
                                    </div>
                                </div>
                                <div class="d-flex align-items-center">
                                    <div class="bg-light rounded p-2 me-3 text-primary"><i class="bi bi-people"></i></div>
                                    <div>
                                        <span class="d-block fw-bold">Attendees: @session.EnrolledCount / @session.MaxAttendees</span>
                                        <small class="text-muted">Potential earnings: @(session.EnrolledCount * session.CreditCost) credits</small>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="card-footer bg-transparent border-top-0 p-4 pt-0 d-flex gap-2">
                            <a asp-action="Details" asp-route-id="@session.Id" class="btn btn-outline-primary rounded-pill w-100">View Details</a>
                            
                            @if (session.Status == StudySync.Models.SessionStatus.Open)
                            {
                                <form asp-action="Complete" asp-route-id="@session.Id" method="post" class="w-100">
                                    <button type="submit" class="btn btn-success w-100 rounded-pill" onclick="return confirm('Mark this session as completed?');">
                                        <i class="bi bi-check2-all me-1"></i>Complete
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
