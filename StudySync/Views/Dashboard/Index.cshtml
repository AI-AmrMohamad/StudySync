@model StudySync.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="container py-5">
    <div class="row mb-5 align-items-center">
        <div class="col-md-8">
            <h1 class="display-4 fw-bold gradient-text mb-2">Welcome back, @Model.FullName!</h1>
            <p class="lead text-muted">Here's an overview of your teaching and learning journey.</p>
        </div>
        <div class="col-md-4 text-md-end mt-3 mt-md-0">
            <a asp-controller="Session" asp-action="Create" class="btn btn-primary btn-lg rounded-pill fw-bold shadow-sm hover-lift">
                <i class="bi bi-plus-lg me-2"></i>Host Session
            </a>
        </div>
    </div>

    <!-- Stats Row -->
    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 h-100 p-4 position-relative overflow-hidden" style="background: linear-gradient(135deg, rgba(124,58,237,0.1), rgba(244,114,182,0.1)); border-left: 4px solid var(--ss-primary) !important;">
                <div class="position-absolute top-0 end-0 p-3 opacity-25">
                    <i class="bi bi-coin" style="font-size: 4rem;"></i>
                </div>
                <h6 class="text-uppercase fw-bold text-muted mb-2">Time Credits</h6>
                <h2 class="display-5 fw-bold mb-0 text-dark">@Model.TimeCredits</h2>
                <p class="small text-muted mt-2 mb-0">Use credits to join sessions</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 h-100 p-4 position-relative overflow-hidden">
                <div class="position-absolute top-0 end-0 p-3 text-primary opacity-25">
                    <i class="bi bi-person-video3" style="font-size: 4rem;"></i>
                </div>
                <h6 class="text-uppercase fw-bold text-muted mb-2">Sessions Hosted</h6>
                <h2 class="display-5 fw-bold mb-0 text-dark">@Model.SessionsHosted</h2>
                <a asp-controller="Session" asp-action="MyHosted" class="stretched-link text-decoration-none mt-2 d-inline-block small fw-bold">View Hosted <i class="bi bi-arrow-right"></i></a>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 h-100 p-4 position-relative overflow-hidden">
                <div class="position-absolute top-0 end-0 p-3 text-success opacity-25">
                    <i class="bi bi-journal-bookmark" style="font-size: 4rem;"></i>
                </div>
                <h6 class="text-uppercase fw-bold text-muted mb-2">Sessions Joined</h6>
                <h2 class="display-5 fw-bold mb-0 text-dark">@Model.SessionsJoined</h2>
                <a asp-controller="Session" asp-action="MyJoined" class="stretched-link text-decoration-none mt-2 d-inline-block small fw-bold text-success">View Joined <i class="bi bi-arrow-right"></i></a>
            </div>
        </div>
    </div>

    <div class="row g-5">
        <!-- Upcoming Sessions -->
        <div class="col-lg-7">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="fw-bold m-0"><i class="bi bi-calendar-check text-primary me-2"></i>Upcoming Schedule</h3>
                <a asp-controller="Session" asp-action="Browse" class="btn btn-sm btn-outline-primary rounded-pill fw-bold">Browse All</a>
            </div>

            @if (!Model.UpcomingSessions.Any())
            {
                <div class="card border-0 shadow-sm rounded-4 p-5 text-center bg-light">
                    <i class="bi bi-calendar-x text-muted mb-3" style="font-size: 3rem;"></i>
                    <h5 class="fw-bold">No upcoming sessions</h5>
                    <p class="text-muted mb-0">You have no scheduled sessions right now.</p>
                </div>
            }
            else
            {
                <div class="d-flex flex-column gap-3">
                    @foreach (var session in Model.UpcomingSessions)
                    {
                        <div class="card border-0 shadow-sm rounded-4 hover-lift">
                            <div class="card-body p-4">
                                <div class="row align-items-center">
                                    <div class="col-md-3 text-center text-md-start mb-3 mb-md-0 border-md-end border-light">
                                        <div class="fw-bold text-primary fs-5">@session.ScheduledAt.ToString("MMM dd")</div>
                                        <div class="text-muted">@session.ScheduledAt.ToString("h:mm tt")</div>
                                        <div class="small text-muted mt-1"><i class="bi bi-clock me-1"></i>@session.DurationMinutes min</div>
                                    </div>
                                    <div class="col-md-6 mb-3 mb-md-0 px-md-4">
                                        @if (session.IsHost)
                                        {
                                            <span class="badge bg-primary rounded-pill mb-2">Hosting</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success rounded-pill mb-2">Enrolled</span>
                                        }
                                        <h5 class="fw-bold mb-1">@session.Title</h5>
                                        <p class="text-muted small mb-0"><i class="bi bi-tag-fill me-1"></i>@session.Topic</p>
                                    </div>
                                    <div class="col-md-3 text-center text-md-end">
                                        <a asp-controller="Session" asp-action="Details" asp-route-id="@session.Id" class="btn btn-outline-primary rounded-pill w-100">Details</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Recent Transactions -->
        <div class="col-lg-5">
            <h3 class="fw-bold mb-4"><i class="bi bi-clock-history text-primary me-2"></i>Recent Activity</h3>
            <div class="card border-0 shadow-sm rounded-4 p-0 overflow-hidden">
                @if (!Model.RecentTransactions.Any())
                {
                    <div class="p-5 text-center">
                        <p class="text-muted m-0">No recent transactions.</p>
                    </div>
                }
                else
                {
                    <div class="list-group list-group-flush">
                        @foreach (var tx in Model.RecentTransactions)
                        {
                            <div class="list-group-item p-4 border-0 border-bottom">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <div class="fw-bold mb-1">
                                            @if (tx.Type == StudySync.Models.TransactionType.SessionJoin)
                                            {
                                                <i class="bi bi-arrow-up-right-circle text-danger me-2"></i><span>Paid to Join Session</span>
                                            }
                                            else if (tx.Type == StudySync.Models.TransactionType.SessionEarned)
                                            {
                                                <i class="bi bi-arrow-down-left-circle text-success me-2"></i><span>Earned from Attendee</span>
                                            }
                                            else if (tx.Type == StudySync.Models.TransactionType.SessionRefund)
                                            {
                                                <i class="bi bi-arrow-counterclockwise text-warning me-2"></i><span>Session Refund</span>
                                            }
                                            else
                                            {
                                                <i class="bi bi-info-circle text-primary me-2"></i><span>Admin Adjustment</span>
                                            }
                                        </div>
                                        <small class="text-muted d-block">@tx.Note</small>
                                        <small class="text-muted d-block" style="font-size: 0.7rem;">@tx.CreatedAt.ToString("MMM dd, h:mm tt")</small>
                                    </div>
                                    <div class="fw-bold fs-5 @(tx.AmountChange >= 0 ? "text-success" : "text-danger")">
                                        @(tx.AmountChange > 0 ? "+" : "")@tx.AmountChange
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>
