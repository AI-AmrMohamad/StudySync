@model StudySync.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="row mb-5 align-items-center">
    <div class="col-md-8">
        <h1 class="display-5 fw-bold mb-1">
            Welcome, <span class="text-gradient">@Model.FullName</span>! <span class="fs-2">👋</span>
        </h1>
        <p class="text-muted fs-5 mb-0">Major: <span class="badge" style="background: rgba(108, 92, 231, 0.1); color: var(--ss-primary); font-size: 0.9rem;">@Model.Major</span></p>
    </div>
</div>

<div class="row g-4 mb-5">
    <!-- Time Credits Wallet Card -->
    <div class="col-md-4">
        <div class="wallet-card wallet-card-credits h-100 p-4 text-white text-center d-flex flex-column justify-content-center">
            <div class="glow-ring mx-auto mb-3">
                <i class="bi bi-coin wallet-icon"></i>
            </div>
            <h2 class="wallet-value mb-1" id="time-credits-display">@Model.TimeCredits</h2>
            <div class="wallet-label mt-2">Time-Credits</div>
        </div>
    </div>

    <!-- Focus Points Wallet Card -->
    <div class="col-md-4">
        <div class="wallet-card wallet-card-points h-100 p-4 text-white text-center d-flex flex-column justify-content-center">
            <div class="glow-ring mx-auto mb-3" style="border-color: rgba(255,255,255,0.4);">
                <i class="bi bi-lightning-fill wallet-icon text-warning"></i>
            </div>
            <h2 class="wallet-value mb-1" id="focus-points-display">@Model.FocusPoints</h2>
            <div class="wallet-label mt-2">Focus Points</div>
        </div>
    </div>

    <!-- Quick Actions Card -->
    <div class="col-md-4">
        <div class="wallet-card wallet-card-action h-100 p-4 text-white text-center d-flex flex-column justify-content-center">
            <div class="mb-4">
                <i class="bi bi-broadcast" style="font-size: 3.5rem; opacity: 0.9; filter: drop-shadow(0 2px 5px rgba(0,0,0,0.5)); color: var(--ss-gold);"></i>
            </div>
            <a asp-controller="LiveSessions" asp-action="Create" class="btn btn-warning text-dark fw-bold mb-3 shadow-sm hover-lift" style="font-size: 1.1rem; padding: 0.8rem;">
                <i class="bi bi-plus-circle me-2"></i>Create Session
            </a>
            <a asp-controller="LiveSessions" asp-action="Index" class="btn btn-outline-light hover-lift">
                <i class="bi bi-broadcast me-2"></i>Browse Sessions
            </a>
        </div>
    </div>
</div>

<!-- My Teaching Sessions -->
@if (Model.MySessions.Any())
{
    <div class="row mb-4">
        <div class="col-12">
            <div class="card card-no-hover">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-2 px-4">
                    <h4 class="section-title mb-0">
                        <i class="bi bi-mortarboard bg-light p-2 rounded-3"></i> My Teaching Sessions
                    </h4>
                </div>
                <div class="card-body p-4 pt-2">
                    <div class="list-group list-group-flush border-top">
                        @foreach (var session in Model.MySessions)
                        {
                            var isLive = session.Status == StudySync.Models.SessionStatus.Live;
                            <div class="feed-item d-flex align-items-center justify-content-between flex-wrap gap-3">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="bg-light rounded-circle d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                                        <i class="bi bi-broadcast fs-4" style="color: @(isLive ? "#DC2626" : "#7C3AED");"></i>
                                    </div>
                                    <div>
                                        <h5 class="mb-1 fw-bold">@session.Title</h5>
                                        <p class="mb-0 text-muted fs-6">
                                            <span class="badge" style="background: rgba(124,58,237,0.1); color: #7C3AED; font-size: 0.7rem;">@session.SkillName</span>
                                            &bull; @session.ScheduledAt.ToString("MMM dd, hh:mm tt")
                                        </p>
                                    </div>
                                </div>

                                <div class="text-center px-3 border-start border-end d-none d-md-block">
                                    <h5 class="mb-0 fw-bold">@session.EnrolledCount/@session.MaxAttendees</h5>
                                    <small class="text-muted text-uppercase" style="font-size: 0.65rem; letter-spacing: 0.05em;">Enrolled</small>
                                </div>

                                <div class="d-flex align-items-center gap-3">
                                    <div class="text-end">
                                        @if (isLive)
                                        {
                                            <span class="badge bg-danger px-2 py-1 d-flex align-items-center gap-1">
                                                <span class="d-inline-block rounded-circle bg-white" style="width:6px;height:6px;animation: pulse 1.5s infinite;"></span>
                                                LIVE
                                            </span>
                                        }
                                        else if (session.Status == StudySync.Models.SessionStatus.Completed)
                                        {
                                            <span class="badge bg-secondary px-2 py-1">Completed</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark px-2 py-1">Upcoming</span>
                                        }
                                    </div>
                                    <a asp-controller="LiveSessions" asp-action="Room" asp-route-id="@session.Id"
                                       class="btn @(isLive ? "btn-danger" : "btn-primary") btn-sm" style="border-radius: 50rem;">
                                        <i class="bi bi-door-open me-1"></i>@(isLive ? "Rejoin" : "Enter")
                                    </a>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- Enrolled Sessions -->
<div class="row">
    <div class="col-12">
        <div class="card card-no-hover">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-2 px-4">
                <h4 class="section-title mb-0">
                    <i class="bi bi-calendar-check bg-light p-2 rounded-3"></i> My Enrolled Sessions
                </h4>
            </div>
            <div class="card-body p-4 pt-2">
                @if (Model.UpcomingSessions.Any())
                {
                    <div class="list-group list-group-flush border-top">
                        @foreach (var session in Model.UpcomingSessions)
                        {
                            var isLive = session.Status == StudySync.Models.SessionStatus.Live;
                            <div class="feed-item d-flex align-items-center justify-content-between flex-wrap gap-3">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="bg-light rounded-circle d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                                        <i class="bi @(isLive ? "bi-broadcast text-danger" : "bi-calendar-event") fs-4" style="color: @(isLive ? "#DC2626" : "#7C3AED");"></i>
                                    </div>
                                    <div>
                                        <h5 class="mb-1 fw-bold">@session.Title</h5>
                                        <p class="mb-0 text-muted fs-6">
                                            By <strong>@session.TutorName</strong> &bull;
                                            <span class="badge" style="background: rgba(124,58,237,0.1); color: #7C3AED; font-size: 0.7rem;">@session.SkillName</span>
                                            &bull; @session.ScheduledAt.ToString("MMM dd, hh:mm tt")
                                        </p>
                                    </div>
                                </div>

                                <div class="text-center px-3 border-start border-end d-none d-md-block">
                                    <h5 class="mb-0 fw-bold">@session.CreditCost <i class="bi bi-coin text-warning fs-6"></i></h5>
                                    <small class="text-muted text-uppercase" style="font-size: 0.65rem; letter-spacing: 0.05em;">Paid</small>
                                </div>

                                <div class="d-flex align-items-center gap-3">
                                    <div class="text-end">
                                        @if (isLive)
                                        {
                                            <span class="badge bg-danger px-2 py-1 d-flex align-items-center gap-1">
                                                <span class="d-inline-block rounded-circle bg-white" style="width:6px;height:6px;animation: pulse 1.5s infinite;"></span>
                                                LIVE
                                            </span>
                                        }
                                        else if (session.Status == StudySync.Models.SessionStatus.Completed)
                                        {
                                            <span class="badge bg-secondary px-2 py-1">Completed</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success px-2 py-1">Enrolled</span>
                                        }
                                    </div>
                                    @if (session.Status != StudySync.Models.SessionStatus.Completed)
                                    {
                                        <a asp-controller="LiveSessions" asp-action="Room" asp-route-id="@session.Id"
                                           class="btn @(isLive ? "btn-danger" : "btn-primary") btn-sm" style="border-radius: 50rem;">
                                            <i class="bi bi-door-open me-1"></i>@(isLive ? "Join Now" : "Enter Room")
                                        </a>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-state p-5 bg-white rounded-4 shadow-sm border border-light mt-3">
                        <div class="empty-state-icon">
                            <i class="bi bi-broadcast text-primary" style="font-size: 5rem; opacity: 0.6;"></i>
                        </div>
                        <h4 class="fw-bold mt-3">No enrolled sessions yet!</h4>
                        <p class="text-muted mb-4 lead">Browse live sessions and enroll to start learning from tutors.</p>
                        <a asp-controller="LiveSessions" asp-action="Index" class="btn btn-primary btn-lg shadow hover-lift rounded-pill px-5">
                            <i class="bi bi-search me-2"></i>Browse Sessions
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <style>
        @@keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.3; }
        }
    </style>
}
