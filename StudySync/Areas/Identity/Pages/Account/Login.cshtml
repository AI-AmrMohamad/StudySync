@page
@model StudySync.Areas.Identity.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Log in";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-5">
        <div class="card border-0 shadow-sm">
            <div class="card-header text-white border-0 py-3" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                <h3 class="mb-0 fw-bold text-center">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Welcome Back
                </h3>
                <p class="text-center text-white-50 mb-0 mt-1">Log in to your StudySync account</p>
            </div>
            <div class="card-body p-4">
                <form id="loginForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="Input.Email" class="form-label fw-bold"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                            <input asp-for="Input.Email" class="form-control" autocomplete="username"
                                   placeholder="your@email.com" id="login-email" />
                        </div>
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Password" class="form-label fw-bold"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-lock"></i></span>
                            <input asp-for="Input.Password" class="form-control" autocomplete="current-password"
                                   placeholder="Enter your password" id="login-password" />
                        </div>
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <div class="form-check">
                            <input asp-for="Input.RememberMe" class="form-check-input" id="login-remember" />
                            <label asp-for="Input.RememberMe" class="form-check-label"></label>
                        </div>
                    </div>

                    <div class="d-grid">
                        <button id="login-submit" type="submit" class="btn btn-primary btn-lg fw-bold">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Log In
                        </button>
                    </div>

                    <div class="text-center mt-3">
                        <p class="text-muted">Don't have an account?
                            <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="text-primary fw-bold">Register</a>
                        </p>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
