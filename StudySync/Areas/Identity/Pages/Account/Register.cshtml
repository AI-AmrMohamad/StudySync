@page
@model StudySync.Areas.Identity.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-5">
        <div class="card border-0 shadow-sm">
            <div class="card-header text-white border-0 py-3" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                <h3 class="mb-0 fw-bold text-center">
                    <i class="bi bi-person-plus me-2"></i>Create Account
                </h3>
                <p class="text-center text-white-50 mb-0 mt-1">Join the StudySync ecosystem</p>
            </div>
            <div class="card-body p-4">
                <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="Input.FullName" class="form-label fw-bold"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-person"></i></span>
                            <input asp-for="Input.FullName" class="form-control" autocomplete="name"
                                   placeholder="Your full name" id="register-fullname" />
                        </div>
                        <span asp-validation-for="Input.FullName" class="text-danger"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.UniversityName" class="form-control" autocomplete="organization" aria-required="true" placeholder="NYU, MIT, etc." />
                        <label asp-for="Input.UniversityName">University</label>
                        <span asp-validation-for="Input.UniversityName" class="text-danger"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.Major" class="form-control" autocomplete="organization-title" aria-required="true" placeholder="Computer Science, Physics, etc." />
                        <label asp-for="Input.Major">Major</label>
                        <span asp-validation-for="Input.Major" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Email" class="form-label fw-bold"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                            <input asp-for="Input.Email" class="form-control" autocomplete="username"
                                   placeholder="your@email.com" id="register-email" />
                        </div>
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Password" class="form-label fw-bold"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-lock"></i></span>
                            <input asp-for="Input.Password" class="form-control" autocomplete="new-password"
                                   placeholder="Minimum 6 characters" id="register-password" />
                        </div>
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Input.ConfirmPassword" class="form-label fw-bold"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-lock-fill"></i></span>
                            <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password"
                                   placeholder="Re-enter password" id="register-confirm-password" />
                        </div>
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                    </div>

                    <div class="d-grid">
                        <button id="registerSubmit" type="submit" class="btn btn-primary btn-lg fw-bold">
                            <i class="bi bi-rocket-takeoff me-2"></i>Create Account
                        </button>
                    </div>

                    <div class="text-center mt-3">
                        <p class="text-muted">Already have an account?
                            <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" class="text-primary fw-bold">Log in</a>
                        </p>
                    </div>
                </form>
            </div>
            <div class="card-footer bg-light text-center text-muted small border-0 py-3">
                <i class="bi bi-coin text-warning me-1"></i> New accounts start with <strong>5 Time-Credits</strong>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
